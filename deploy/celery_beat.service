[Unit]
Description=Voice AI Agent — Celery Beat Scheduler
After=network.target redis.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/voice_ai_agent
Environment="DJANGO_SETTINGS_MODULE=config.settings.production"
ExecStart=/opt/voice_ai_agent/venv/bin/celery \
          -A config beat \
          --loglevel=info \
          --logfile=/var/log/voice_ai_agent/celery_beat.log
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
