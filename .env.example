# =============================================================================
# Voice AI Agent — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in every value before starting the service.
# Lines starting with # are comments and are ignored.
# Do NOT commit the real .env file to version control.
# =============================================================================

# ── Django core ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated list of hostnames/IPs Django will accept requests for.
# Example: 192.168.1.10,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── URLs (deployment-specific) ────────────────────────────────────────────────
# Public base URL of this installation — used in email links and API callbacks.
# Example: http://192.168.1.10  or  https://yourdomain.com
APP_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# URL where the Vue portal is served (used in email notification links).
PORTAL_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# CORS allowed origins — comma-separated.
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN

# Internal URL that Asterisk AGI scripts use to reach Django (keep localhost).
DJANGO_API_BASE_URL=http://127.0.0.1:8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=voice_ai_db
DB_USER=voice_ai_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_VECTOR_STORE_ID=vs_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=Your Company Name <your-email@example.com>
PORTAL_NOTIFICATION_EMAILS=admin@example.com

# ── Asterisk bridge ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ASTERISK_SECRET=your-shared-secret

# ── Asterisk / telephony settings ─────────────────────────────────────────────
HUMAN_TRANSFER_EXTENSION=agent200
MAX_CONVERSATION_TURNS=10
TURN_RECORD_TIMEOUT=30
TURN_SILENCE_TIMEOUT=5
WELCOME_SOUND_NAME=welcome_future_smart

# ── File system paths ─────────────────────────────────────────────────────────
MEDIA_ROOT=/home/agent/voice_ai_agent/media/calls
COMPANY_DOCS_ROOT=/home/agent/voice_ai_agent/company_docs
LOG_FILE=/var/log/voice_ai_agent/app.log
ASTERISK_RECORDINGS_DIR=/var/spool/asterisk/monitor
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds/custom

# ── Branding ──────────────────────────────────────────────────────────────────
COMPANY_NAME=Future Smart Support
ALERT_CONFIDENCE_THRESHOLD=0.6
