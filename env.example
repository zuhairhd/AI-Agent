# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=voice_ai_db
DB_USER=voice_ai_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Persistent vector store ID for the company knowledge base.
# How to obtain:
#   1. Leave this blank on first run.
#   2. Upload one document via the Django admin.
#   3. The Celery worker will create a new vector store and log its ID:
#        "NEW VECTOR STORE CREATED: vs_xxxx"
#   4. Copy that ID here and restart services.
# Once set, ALL document uploads reuse this single store — do not change it.
OPENAI_VECTOR_STORE_ID=vs_...

# ── Asterisk bridge ───────────────────────────────────────────────────────────
ASTERISK_SECRET=change-me-to-a-shared-secret

# ── File paths ────────────────────────────────────────────────────────────────
MEDIA_ROOT=/home/agent/voice_ai_agent/media/calls
COMPANY_DOCS_ROOT=/home/agent/voice_ai_agent/company_docs
LOG_FILE=/var/log/voice_ai_agent/app.log
