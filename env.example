# =============================================================================
# Voice AI Agent — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in every value before starting the service.
# Lines starting with # are comments and are ignored.
# Do NOT commit the real .env file to version control.
# =============================================================================

# ── Django core ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated list of hostnames/IPs Django will accept requests for.
# Include your server's IP address and/or domain name.
# Example: 192.168.1.10,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── URLs (deployment-specific) ────────────────────────────────────────────────
# Public base URL of this installation — used in email links and API callbacks.
# Example: http://192.168.1.10  or  https://yourdomain.com
APP_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# URL where the Vue portal is served (used in email notification links).
# Typically the same as APP_BASE_URL unless the frontend is on a separate host.
PORTAL_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# CORS allowed origins — comma-separated list of origins allowed to make
# cross-origin requests to the Django API.
# Example: http://192.168.1.10,http://yourdomain.com
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN

# Internal URL that Asterisk AGI and shell scripts use to reach Django.
# Keep this as localhost since both Asterisk and Django run on the same server.
DJANGO_API_BASE_URL=http://127.0.0.1:8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=voice_ai_db
DB_USER=voice_ai_user
# Set this to the password you entered during setup.sh (step 3).
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Persistent vector store ID for the company knowledge base.
# How to obtain:
#   1. Leave this blank on first run.
#   2. Upload one document via the Django admin.
#   3. The Celery worker will create a new vector store and log its ID:
#        "NEW VECTOR STORE CREATED: vs_xxxx"
#   4. Copy that ID here and restart services.
# Once set, ALL document uploads reuse this single store — do not change it.
OPENAI_VECTOR_STORE_ID=vs_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password).
# Google account → Security → 2-Step Verification → App passwords.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
# Friendly "From" name shown in notification emails.
DEFAULT_FROM_EMAIL=Your Company Name <your-email@example.com>
# Comma-separated list of addresses that receive portal alert emails.
# Leave blank to disable email notifications globally.
PORTAL_NOTIFICATION_EMAILS=admin@example.com

# ── Asterisk bridge ───────────────────────────────────────────────────────────
# Shared secret between Asterisk AGI scripts and the Django API.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match the value set in /etc/asterisk/asterisk.env on the server.
ASTERISK_SECRET=change-me-to-a-shared-secret

# ── Asterisk / telephony settings ─────────────────────────────────────────────
# PJSIP endpoint name of the human agent softphone (must match pjsip.conf).
HUMAN_TRANSFER_EXTENSION=agent200
# Maximum conversation turns before the AI hands off or hangs up.
MAX_CONVERSATION_TURNS=10
# Total recording timeout per turn (seconds).
TURN_RECORD_TIMEOUT=30
# Silence duration that ends a recording (seconds).
TURN_SILENCE_TIMEOUT=5
# Filename (without extension) of the welcome/greeting sound in Asterisk sounds dir.
WELCOME_SOUND_NAME=welcome_future_smart

# ── File system paths ─────────────────────────────────────────────────────────
# Absolute path where call audio recordings are stored.
MEDIA_ROOT=/home/agent/voice_ai_agent/media/calls
# Absolute path where company knowledge-base documents are stored.
COMPANY_DOCS_ROOT=/home/agent/voice_ai_agent/company_docs
# Absolute path to the application log file.
LOG_FILE=/var/log/voice_ai_agent/app.log
# Directory where Asterisk writes caller recordings (must match pjsip/dialplan).
ASTERISK_RECORDINGS_DIR=/var/spool/asterisk/monitor
# Directory where Asterisk looks for custom sound files.
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds/custom

# ── Branding ──────────────────────────────────────────────────────────────────
# Company name shown in email notifications and AI responses.
COMPANY_NAME=Future Smart Support

# ── Alert tuning ──────────────────────────────────────────────────────────────
# Minimum AI confidence score (0.0–1.0) required before raising an alert.
ALERT_CONFIDENCE_THRESHOLD=0.6
